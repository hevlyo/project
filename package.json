{
  "name": "pegabola3000",
  "version": "1.0.0",
  "private": true,
  "description": "Pega Bola 3000",
  "author": "Riquelme",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/shared build && bun run --cwd apps/game build && bun run --cwd apps/server build",
    "start": "bun run build && node apps/server/dist/server.js",
    "test": "bun run --cwd apps/server test",
    "test:e2e": "bun run --cwd apps/server test:e2e",
    "test:e2e:install": "bun run --cwd apps/server test:e2e:install",
    "deploy": "bash scripts/deploy-production.sh"
  }
}
