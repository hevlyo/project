{
  "name": "@pegabola/server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "bun run build && node dist/server.js",
    "dev": "bun run build && node --watch dist/server.js",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:install": "playwright install chromium",
    "coverage": "vitest run -c vitest.config.ts --coverage"
  },
  "dependencies": {
    "@pegabola/shared": "workspace:*",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.3",
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "4.1.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
